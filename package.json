{
  "name": "loot-and-liability",
  "private": true,
  "version": "1.7.2",
  "appVersion": "1.7.2.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "npm run sync:assets && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "verify": "npm test && npm run build",
    "sync:assets": "node scripts/sync-assets.mjs",
    "release:web": "node scripts/release-web.mjs",
    "release:windows": "node scripts/release-windows.mjs",
    "release:android": "node scripts/release-android.mjs",
    "release:all": "npm run release:web && npm run release:windows && npm run release:android"
  },
  "dependencies": {
    "@capacitor/android": "^8.2.0",
    "@capacitor/core": "^8.2.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.2.0",
    "@rollup/rollup-win32-x64-msvc": "^4.57.1",
    "@tauri-apps/cli": "^2.10.1",
    "@tauri-apps/cli-win32-x64-msvc": "^2.10.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@vitejs/plugin-react": "^5.1.4",
    "autoprefixer": "^10.4.16",
    "jsdom": "^28.1.0",
    "postcss": "^8.4.32",
    "sharp": "^0.34.5",
    "tailwindcss": "^3.4.0",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
